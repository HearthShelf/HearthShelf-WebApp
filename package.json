{
  "name": "hearthshelf-webapp",
  "version": "0.1.0",
  "description": "The hosted HearthShelf web application - a unified front door (app.hearthshelf.com) for reaching any HearthShelf / AudiobookShelf server you have access to.",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "sync-core": "git submodule update --remote packages/core"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@tanstack/react-query": "^5.101.2",
    "epubjs": "^0.4.2",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "@clerk/shared@3.47.7": true
  }
}
