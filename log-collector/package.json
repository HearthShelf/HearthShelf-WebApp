{
  "name": "hearthshelf-log-collector",
  "version": "0.1.0",
  "description": "Isolated Cloudflare Worker that ingests warn/error infra logs (VPS cert broker, control plane, self-hosted boxes) into a dedicated D1 database. Holds NO control-plane secrets and no control-plane DB binding.",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply hearthshelf-logs --local",
    "db:migrate:remote": "wrangler d1 migrations apply hearthshelf-logs --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  },
  "allowScripts": {
    "esbuild@0.17.19": true,
    "workerd@1.20250718.0": true
  }
}
