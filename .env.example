# HearthShelf WebApp - environment variables.
# Copy to .env.local for local dev; set the same in the Cloudflare Pages
# project (as PLAINTEXT build variables, not Secrets - VITE_ vars are baked into
# the bundle at build time and are public by design).

# Clerk publishable key (public; starts with pk_). Required.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# Control-plane API base. Defaults to the local wrangler dev port if unset.
VITE_CONTROL_PLANE_URL=https://api.hearthshelf.com

# Clerk redirect config, code/env-side (preferred over dashboard component
# paths, which Clerk is deprecating). The Clerk SDK reads these automatically.
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
